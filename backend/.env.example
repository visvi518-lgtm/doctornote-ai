# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/healthweb

# Security
SECRET_KEY=your-very-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

